# Application
APP_NAME=fe-brief
APP_ENV=local

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=4321
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

# Database
POSTGRES_DB=fe_brief
POSTGRES_USER=fe_brief
POSTGRES_PASSWORD=fe_brief
DATABASE_URL=postgresql+psycopg://fe_brief:fe_brief@localhost:5432/fe_brief

# Redis
REDIS_URL=redis://redis:6379/0

# Fetch configuration
SOURCES_FILE=sources.yaml
FETCH_INTERVAL_SECONDS=3600
