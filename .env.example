# Application
APP_NAME=fe-brief
APP_ENV=local

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=4321

# Database
POSTGRES_DB=fe_brief
POSTGRES_USER=fe_brief
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://fe_brief:change-me@postgres:5432/fe_brief

# Redis
REDIS_URL=redis://redis:6379/0

# Fetch configuration
SOURCES_FILE=sources.yaml
FETCH_INTERVAL_SECONDS=3600
